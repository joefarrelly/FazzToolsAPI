# Django
SECRET_KEY=your-secret-key-here
DEBUG_OPTION=True

# Database (matches docker-compose MySQL service)
DB_NAME=fazztools
DB_USER=fazztools
DB_PASSWORD=fazztools
DB_ROOT_PASSWORD=rootpassword
DB_HOST=db
DB_PORT=3306

# Celery broker (matches docker-compose Redis service)
CELERY_BROKER_URL=redis://redis:6379/0

# Blizzard API
HASH_KEY=your-hash-key-here
BLIZZ_CLIENT=your-blizzard-client-id
BLIZZ_SECRET=your-blizzard-client-secret
BLIZZ_REDIRECT_URI=http://localhost:3000/callback

# Admin-only data scan trigger
DATA_PASSWORD=your-data-password-here
